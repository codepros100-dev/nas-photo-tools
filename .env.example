# Copy to .env (next to scripts/ or in ~/.nas-photo-tools/) and fill in.
# scripts/nas_config.py will load this automatically.

# --- SMB credentials (only needed for verify_hash_db.py and SMB uploads) ---
NAS_HOST=192.168.1.10
NAS_USER=your_smb_user
NAS_PASS=your_smb_password
NAS_SHARE=Photos

# Optional NetBIOS / protocol tweaks
# NAS_CLIENT_NAME=LAPTOP
# NAS_SERVER_NAME=NAS
# NAS_USE_NTLMV2=true
# NAS_DIRECT_TCP=true

# --- Local paths ---
# Where the photo library is mounted locally. Recommended: map your share
# as a drive letter (Windows) or mount it (macOS/Linux).
PHOTO_LIBRARY_ROOT=P:/Library

# Where the analysis SQLite, logs, and downloaded models are kept.
# Defaults to ~/.nas-photo-tools/
# PHOTO_DB_DIR=
